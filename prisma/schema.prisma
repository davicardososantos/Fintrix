// Fintrix — schema inicial. Reflete docs/data-model.md.
// Regras: dinheiro em centavos (Int); isolamento por householdId; import idempotente (dedupHash).
// Auth é credentials-only (JWT) — sem tabelas de adapter NextAuth por ora; por isso a conta
// financeira se chama `FinancialAccount` (evita colisão futura com `Account` de OAuth).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  member
}

enum AccountType {
  checking
  credit_card
  meal_voucher
  cash
  other
}

enum ImportSource {
  c6_extrato
  c6_fatura
  alelo
  nubank_conta
  santander_conta // reservado (Santander virá depois)
}

enum CategoryKind {
  expense
  income
  transfer
  investment
}

enum CategorySource {
  c6
  rule
  ai
  manual
  uncategorized
}

enum RuleMatchType {
  contains
  regex
  equals
}

enum PointsProgramName {
  smiles
  livelo
  azul
  latam
}

enum InvestmentType {
  cdb
  other
}

enum BillRecurrence {
  monthly // conta fixa que se repete todo mês
  one_time // conta avulsa (paga uma vez)
}

model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users             User[]
  accounts          FinancialAccount[]
  categories        Category[]
  rules             CategoryRule[]
  importBatches     ImportBatch[]
  transactions      Transaction[]
  pointsPrograms    PointsProgram[]
  investments       Investment[]
  bills             Bill[]
  billPayments      BillPayment[]
  pushSubscriptions PushSubscription[]
}

model User {
  id           String   @id @default(cuid())
  householdId  String
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(member)
  createdAt    DateTime @default(now())

  household          Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ownedTransactions  Transaction[]      @relation("TransactionOwner")
  importBatches      ImportBatch[]
  defaultForAccounts FinancialAccount[] @relation("AccountDefaultOwner")
  pointsPrograms     PointsProgram[]
  investments        Investment[]
  bills              Bill[]
  pushSubscriptions  PushSubscription[]

  @@index([householdId])
}

model FinancialAccount {
  id               String      @id @default(cuid())
  householdId      String
  name             String
  type             AccountType
  institution      String?
  last4            String?
  defaultOwnerId   String?
  balanceCents     Int? // saldo atual informado manualmente (null = não informado)
  balanceUpdatedAt DateTime? // quando o saldo foi atualizado pela última vez

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  defaultOwner User?         @relation("AccountDefaultOwner", fields: [defaultOwnerId], references: [id])
  transactions Transaction[]

  @@unique([householdId, name])
  @@index([householdId])
}

model ImportBatch {
  id           String       @id @default(cuid())
  householdId  String
  source       ImportSource
  fileName     String
  fileHash     String
  importedById String
  periodStart  DateTime?
  periodEnd    DateTime?
  totalRows    Int          @default(0)
  importedRows Int          @default(0)
  skippedRows  Int          @default(0) // duplicadas ignoradas pelo dedup
  errorRows    Int          @default(0) // linhas inválidas puladas
  createdAt    DateTime     @default(now())

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  importedBy   User          @relation(fields: [importedById], references: [id])
  transactions Transaction[]

  @@index([householdId, fileHash])
}

model Transaction {
  id             String         @id @default(cuid())
  householdId    String
  importBatchId  String?
  accountId      String?
  date           DateTime
  description    String
  rawDescription String?        @db.Text
  amountCents    Int // + entrada / - saída
  currency       String         @default("BRL")
  fxAmountCents  Int?
  fxCurrency     String?
  categoryId     String?
  categorySource CategorySource @default(uncategorized)
  rawCategory    String? // categoria original do arquivo (ex.: Categoria da fatura C6) — semente p/ Fase 3
  ownerId        String? // null = casal
  ownerHint      String? // pista de pessoa do arquivo (ex.: Nome no Cartão) — usado na atribuição (Fase 3)
  ownerManual    Boolean        @default(false) // true = atribuição feita à mão (não sobrescrever no auto)
  installment    String?
  dedupHash      String
  createdAt      DateTime       @default(now())

  household   Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  importBatch ImportBatch?      @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  account     FinancialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category    Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  owner       User?             @relation("TransactionOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@unique([householdId, dedupHash])
  @@index([householdId, date])
  @@index([householdId, categoryId])
  @@index([householdId, ownerId])
}

model Category {
  id          String       @id @default(cuid())
  householdId String
  name        String
  kind        CategoryKind @default(expense)
  color       String? // referencia token do tema, não hex cru
  parentId    String?

  household    Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  parent       Category?      @relation("CategoryParent", fields: [parentId], references: [id])
  children     Category[]     @relation("CategoryParent")
  transactions Transaction[]
  rules        CategoryRule[]

  @@unique([householdId, name])
  @@index([householdId])
}

model CategoryRule {
  id          String        @id @default(cuid())
  householdId String
  matchType   RuleMatchType @default(contains)
  pattern     String
  categoryId  String
  priority    Int           @default(100)

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([householdId, priority])
}

model PointsProgram {
  id          String            @id @default(cuid())
  householdId String
  name        PointsProgramName
  ownerId     String?

  household Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  owner     User?            @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  snapshots PointsSnapshot[]

  @@index([householdId])
}

model PointsSnapshot {
  id        String   @id @default(cuid())
  programId String
  balance   Int
  date      DateTime
  note      String?

  program PointsProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId, date])
}

model Investment {
  id             String         @id @default(cuid())
  householdId    String
  name           String
  type           InvestmentType @default(cdb)
  institution    String?
  principalCents Int
  appliedAt      DateTime
  maturityAt     DateTime?
  ownerId        String?

  household Household            @relation(fields: [householdId], references: [id], onDelete: Cascade)
  owner     User?                @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  snapshots InvestmentSnapshot[]

  @@index([householdId])
}

model InvestmentSnapshot {
  id           String   @id @default(cuid())
  investmentId String
  valueCents   Int
  date         DateTime

  investment Investment @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([investmentId, date])
}

// Conta a pagar: lembrete de vencimento. Fixa mensal (recurrence=monthly, dueDay) ou avulsa
// (recurrence=one_time, dueDate). Dinheiro em centavos; ownerId null = casal.
model Bill {
  id          String         @id @default(cuid())
  householdId String
  name        String
  amountCents Int? // valor esperado (opcional — contas como energia variam)
  recurrence  BillRecurrence @default(monthly)
  dueDay      Int? // 1-31, para recorrentes mensais
  dueDate     DateTime? // para avulsas (one_time)
  ownerId     String? // null = casal
  active      Boolean        @default(true)
  notes       String?
  createdAt   DateTime       @default(now())

  household Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  owner     User?         @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  payments  BillPayment[]

  @@index([householdId])
}

// Uma linha = "esta conta foi paga neste mês/ocorrência". Ausência = não paga.
model BillPayment {
  id          String   @id @default(cuid())
  billId      String
  householdId String
  periodKey   String // "YYYY-MM" (mensal) ou mês de vencimento (avulsa)
  paidAt      DateTime @default(now())
  amountCents Int? // valor efetivamente pago (opcional)

  bill      Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([billId, periodKey])
  @@index([householdId])
}

// Assinaturas de push por dispositivo (lembrete de vencimento). endpoint é VarChar(500) por
// causa do limite de índice único em MySQL (TEXT precisaria de prefixo).
model PushSubscription {
  id          String   @id @default(cuid())
  householdId String
  userId      String
  endpoint    String   @unique @db.VarChar(500)
  p256dh      String   @db.Text
  auth        String   @db.Text
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([householdId])
}
