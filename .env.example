# ===== Fintrix — variáveis de ambiente =====
# Copie para .env e ajuste. O .env NÃO é versionado.

# --- Banco (MySQL) ---
DB_NAME=fintrix
DB_USER=fintrix
DB_PASSWORD=fintrix
DB_ROOT_PASSWORD=fintrix_root

# URL usada pelo Prisma.
# - Dentro do Docker (app): host = db, porta 3306
# - Rodando o app LOCALMENTE fora do Docker: host = localhost, porta = DB_PORT (3310)
DATABASE_URL="mysql://fintrix:fintrix@localhost:3310/fintrix"

# --- Auth (NextAuth / Auth.js) ---
# Gere um segredo: `npx auth secret` ou `openssl rand -base64 33`
AUTH_SECRET="troque-por-um-segredo-aleatorio"
AUTH_TRUST_HOST=true
# URL pública da app (para redirects absolutos corretos). Opcional se atrás de proxy com
# X-Forwarded-Host (AUTH_TRUST_HOST=true cuida disso). Local/direto: http://localhost:3100
# Produção: https://seu-dominio
AUTH_URL="http://localhost:3100"

# --- IA (categorização) ---
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-flash-lite"

# --- Portas (host) — dedicadas ao Fintrix, sem colidir com nutrix/codetrix/proxy-manager ---
APP_PORT=3100
DB_PORT=3310
ADMINER_PORT=8090
