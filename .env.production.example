# ===== Fintrix — .env de PRODUÇÃO (VPS Hostinger) =====
# Crie este arquivo UMA VEZ no servidor, em DEPLOY_PATH/.env (ele NÃO é versionado nem enviado
# pelo CI — o rsync do deploy o preserva). Depois de criar, o deploy só faz build + up.

# --- Banco (MySQL do próprio compose) ---
DB_NAME=fintrix
DB_USER=fintrix
DB_PASSWORD=troque-por-uma-senha-forte
DB_ROOT_PASSWORD=troque-por-outra-senha-forte

# Dentro do compose, o app fala com o serviço "db" na porta interna 3306.
DATABASE_URL="mysql://fintrix:troque-por-uma-senha-forte@db:3306/fintrix"

# --- Auth (NextAuth) ---
# Gere: openssl rand -base64 33
AUTH_SECRET="cole-um-segredo-aleatorio-forte"
AUTH_TRUST_HOST=true
# URL pública real do app (o domínio que você apontar no Nginx Proxy Manager):
AUTH_URL="https://fintrix.seudominio.com.br"

# --- IA (categorização) ---
GEMINI_API_KEY="sua-chave-do-gemini"
GEMINI_MODEL="gemini-3.1-flash-lite"

# --- Portas no host do VPS (já escolhidas p/ não colidir com nutrix/codetrix/proxy-manager) ---
APP_PORT=3100
DB_PORT=3310
ADMINER_PORT=8090
